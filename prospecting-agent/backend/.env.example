# CyberProspect Agent — Environment Configuration
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# App settings
APP_NAME="CyberProspect Agent"
DEBUG=false
LOG_LEVEL=INFO

# Database (default: SQLite)
# For Postgres: postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./data/prospecting.db

# LLM provider: "anthropic" (default) or "openai"
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
LLM_MODEL=claude-sonnet-4-6
LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=2048

# Search provider: "duckduckgo" (default, free) or "serpapi"
SEARCH_PROVIDER=duckduckgo
SEARCH_MAX_RESULTS=10
SEARCH_DELAY_SECONDS=2.0
# SERP_API_KEY=your_serpapi_key

# HTTP client
HTTP_TIMEOUT_SECONDS=15
HTTP_MAX_RETRIES=3

# Scoring thresholds
SCORE_THRESHOLD_HIGH=70
SCORE_THRESHOLD_MEDIUM=45

# Export directory
EXPORT_DIR=./data/exports

# Compliance — do not change
REQUIRE_HUMAN_REVIEW=true
